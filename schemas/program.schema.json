{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bum-engine/schemas/program.schema.json",
  "title": "Program",
  "description": "Design brief extracted from natural language. Solver-facing input. version 1.3.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "plot", "orientation", "floors", "spaces", "adjacency"],
  "anyOf": [
    { "required": ["footprint_target_m2"] },
    { "required": ["target_area_m2"] }
  ],
  "properties": {
    "version": { "type": "string", "enum": ["1.0.0", "1.1.0", "1.2.0", "1.3.0"] },
    "plot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width_m", "depth_m"],
      "properties": {
        "width_m": { "type": "number", "exclusiveMinimum": 0, "maximum": 200 },
        "depth_m": { "type": "number", "exclusiveMinimum": 0, "maximum": 200 }
      }
    },
    "orientation": {
      "description": "Compass direction the front/street facade faces.",
      "enum": ["N", "E", "S", "W"]
    },
    "footprint_target_m2": {
      "description": "Gross footprint area, garage included; bounds the solver's footprint band. 1.2.0 name.",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "target_area_m2": {
      "description": "Deprecated 1.0.0/1.1.0 alias of footprint_target_m2. Accepted on input for back-compat.",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "floors": { "type": "integer", "minimum": 1, "maximum": 4 },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/space" }
    },
    "adjacency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "desirable": { "$ref": "#/$defs/pairList" },
        "semi": { "$ref": "#/$defs/pairList" },
        "avoid": { "$ref": "#/$defs/pairList" }
      }
    },
    "site": {
      "description": "1.3.0, optional: setbacks + coverage cap. Absent -> solver defaults (0.5 cap, 3/2/5 m front/side/rear). Never LLM-emitted.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_coverage_ratio": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "setback_front_m": { "type": "number", "minimum": 0 },
        "setback_side_m": { "type": "number", "minimum": 0 },
        "setback_rear_m": { "type": "number", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "zoneId": {
      "description": "Canonical macro-zone identity the solver understands. 'circulation' is 1.1.0, currently inert (no preset places it).",
      "enum": ["living", "dining", "kitchen_laundry", "master_suite", "children", "office", "entry", "garage", "circulation"]
    },
    "category": {
      "enum": ["living", "private", "wet", "service", "circ", "office", "outdoor"]
    },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target_m2", "min_w_m", "min_h_m", "category"],
      "properties": {
        "id": { "$ref": "#/$defs/zoneId" },
        "target_m2": { "type": "number", "exclusiveMinimum": 0 },
        "min_w_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_h_m": { "type": "number", "exclusiveMinimum": 0 },
        "category": { "$ref": "#/$defs/category" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "max_aspect": {
          "anyOf": [{ "type": "null" }, { "type": "number", "exclusiveMinimum": 0 }],
          "description": "1.1.0, optional per-zone override. Not yet read by the solver."
        },
        "min_area_m2": {
          "anyOf": [{ "type": "null" }, { "type": "number", "exclusiveMinimum": 0 }],
          "description": "1.1.0, optional per-zone override. Not yet read by the solver."
        }
      }
    },
    "pairList": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "$ref": "#/$defs/zoneId" }
      }
    }
  }
}
