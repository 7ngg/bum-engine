{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bum-engine/schemas/program.schema.json",
  "title": "Program",
  "description": "Design brief extracted from natural language. Solver-facing input. version 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "plot", "orientation", "target_area_m2", "floors", "spaces", "adjacency"],
  "properties": {
    "version": { "type": "string", "enum": ["1.0.0", "1.1.0"] },
    "plot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width_m", "depth_m"],
      "properties": {
        "width_m": { "type": "number", "exclusiveMinimum": 0, "maximum": 200 },
        "depth_m": { "type": "number", "exclusiveMinimum": 0, "maximum": 200 }
      }
    },
    "orientation": {
      "description": "Compass direction the front/street facade faces.",
      "enum": ["N", "E", "S", "W"]
    },
    "target_area_m2": { "type": "number", "exclusiveMinimum": 0 },
    "floors": { "type": "integer", "minimum": 1, "maximum": 4 },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/space" }
    },
    "adjacency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "desirable": { "$ref": "#/$defs/pairList" },
        "semi": { "$ref": "#/$defs/pairList" },
        "avoid": { "$ref": "#/$defs/pairList" }
      }
    }
  },
  "$defs": {
    "zoneId": {
      "description": "Canonical macro-zone identity the solver understands. 'circulation' is 1.1.0, currently inert (no preset places it).",
      "enum": ["living", "dining", "kitchen_laundry", "master_suite", "children", "office", "entry", "garage", "circulation"]
    },
    "category": {
      "enum": ["living", "private", "wet", "service", "circ", "office", "outdoor"]
    },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target_m2", "min_w_m", "min_h_m", "category"],
      "properties": {
        "id": { "$ref": "#/$defs/zoneId" },
        "target_m2": { "type": "number", "exclusiveMinimum": 0 },
        "min_w_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_h_m": { "type": "number", "exclusiveMinimum": 0 },
        "category": { "$ref": "#/$defs/category" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "max_aspect": {
          "anyOf": [{ "type": "null" }, { "type": "number", "exclusiveMinimum": 0 }],
          "description": "1.1.0, optional per-zone override. Not yet read by the solver."
        },
        "min_area_m2": {
          "anyOf": [{ "type": "null" }, { "type": "number", "exclusiveMinimum": 0 }],
          "description": "1.1.0, optional per-zone override. Not yet read by the solver."
        }
      }
    },
    "pairList": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "$ref": "#/$defs/zoneId" }
      }
    }
  }
}
